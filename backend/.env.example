# App Name
DEBUG=True
APP_NAME="Q-WanFlow"

# Database (Use your existing DB connection string)
DATABASE_URL=postgresql://username:password@localhost/qwen_workflow_db

# Security (Change this to a long random string!)
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Server URL (CRITICAL for AI services to find your assets)
# This should be your server's public IP or Domain in
# BASE_URL=

# Optional: Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

#Allowed Origins
ALLOWED_ORIGINS=*

# Smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SUPPORT_EMAIL=support.qwanflow@gmail.com